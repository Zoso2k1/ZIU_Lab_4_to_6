import React, { useState, useRef } from 'react';

export default function TodoInput({ onAdd }: { onAdd: (text: string) => void }) {
  const [text, setText] = useState('');
  const [statusMsg, setStatusMsg] = useState(''); // Stan dla Live Region

  const handleSubmit = (e: React.FormEvent) => {
    e.preventDefault();
    if (text.trim()) {
      onAdd(text);
      setStatusMsg(`Dodano zadanie: ${text}`); // Ustawienie komunikatu
      setText('');
      // Wyczyść komunikat po chwili, by móc go ogłosić ponownie
      setTimeout(() => setStatusMsg(''), 3000);
    }
  };

  return (
    <form onSubmit={handleSubmit}>
      <label htmlFor="todo-input">Nowe zadanie:</label>
      <input
        id="todo-input"
        type="text"
        value={text}
        onChange={(e) => setText(e.target.value)}
        aria-describedby="todo-hint"
      />
      <button type="submit" aria-label="Dodaj zadanie do listy">Dodaj</button>
      <p id="todo-hint" className="sr-only">Wpisz treść zadania i naciśnij Enter</p>

      {/* 3. ARIA LIVE REGION - ogłasza zmiany dynamicznie */}
      <div role="status" aria-live="polite" className="sr-only">
        {statusMsg}
      </div>
    </form>
  );
}
